# ============================================================
# 数据库连接配置 —— 复制本文件为 db.env 并改成你自己的信息
#   cp db.env.example db.env
# 脚本会优先读取同目录下的 db.env（其次是环境变量）。
# db.env 已加入 .gitignore，不会被提交。
# ============================================================

DB_HOST=localhost
DB_PORT=5432
DB_NAME=edumanage
DB_USER=postgres
DB_PASSWORD=postgres123

# 可选：如果只想用一行 DSN，填了 DB_DSN 就会忽略上面拆分的字段
# DB_DSN=host=localhost port=5432 dbname=edumanage user=postgres password=postgres123
